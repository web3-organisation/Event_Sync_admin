generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  adminSessions  AdminSession[]
  adminSpeakers  AdminSpeaker[]
  adminEvents    AdminEvent[]
  adminRooms     AdminRoom[]

  @@map("admins")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  location    String?
  createdAt   DateTime @default(now()) @map("created_at")

  rooms       Room[]
  sessions    Session[]
  adminEvents AdminEvent[]

  @@map("events")
}

model Room {
  id      String @id @default(uuid())
  name    String
  eventId String @map("event_id")

  event      Event       @relation(fields: [eventId], references: [id])
  sessions   Session[]
  adminRooms AdminRoom[]

  @@map("rooms")
}

model Speaker {
  id        String   @id @default(uuid())
  fullName  String   @map("full_name")
  photoUrl  String?  @map("photo_url")
  bio       String?
  createdAt DateTime @default(now()) @map("created_at")

  speakerLinks    SpeakerLink[]
  sessionSpeakers SessionSpeaker[]
  adminSpeakers   AdminSpeaker[]

  @@map("speakers")
}

model SpeakerLink {
  id        String @id @default(uuid())
  label     String
  url       String
  speakerId String @map("speaker_id")

  speaker Speaker @relation(fields: [speakerId], references: [id])

  @@map("speaker_links")
}

model Session {
  id          String   @id @default(uuid())
  title       String
  description String?
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  capacity    Int?
  eventId     String   @map("event_id")
  roomId      String   @map("room_id")

  event           Event            @relation(fields: [eventId], references: [id])
  room            Room             @relation(fields: [roomId], references: [id])
  sessionSpeakers SessionSpeaker[]
  adminSessions   AdminSession[]
  questions       Question[]

  @@map("sessions")
}

model SessionSpeaker {
  sessionId String @map("session_id")
  speakerId String @map("speaker_id")

  session Session @relation(fields: [sessionId], references: [id])
  speaker Speaker @relation(fields: [speakerId], references: [id])

  @@id([sessionId, speakerId])
  @@map("session_speakers")
}

model Question {
  id         String   @id @default(uuid())
  content    String
  authorName String?  @map("author_name")
  upvotes    Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  sessionId  String   @map("session_id")

  session        Session         @relation(fields: [sessionId], references: [id])

  @@map("questions")
}

model AdminSession {
  adminId   String @map("id_admin")
  sessionId String @map("id_session")

  admin   Admin   @relation(fields: [adminId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])

  @@id([adminId, sessionId])
  @@map("admin_session")
}

model AdminSpeaker {
  adminId   String @map("id_admin")
  speakerId String @map("id_speaker")

  admin   Admin   @relation(fields: [adminId], references: [id])
  speaker Speaker @relation(fields: [speakerId], references: [id])

  @@id([adminId, speakerId])
  @@map("admin_speakers")
}

model AdminRoom {
  adminId String @map("id_admin")
  roomId  String @map("id_room")

  admin Admin @relation(fields: [adminId], references: [id])
  room  Room  @relation(fields: [roomId], references: [id])

  @@id([adminId, roomId])
  @@map("admin_room")
}

model AdminEvent {
  adminId String @map("id_admins")
  eventId String @map("id_events")

  admin Admin @relation(fields: [adminId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@id([adminId, eventId])
  @@map("admin_event")
}
